{
  "name": "central-agent",
  "version": "0.1.0",
  "description": "Vercel cron bot that interacts through Slack and email.",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node --env-file-if-exists=.env dist/src/app.js",
    "dev": "nodemon",
    "check:env": "node --env-file-if-exists=.env --import tsx scripts/check-env.ts",
    "check:slack": "node --env-file-if-exists=.env --import tsx scripts/check-slack.ts",
    "check:notion": "node --env-file-if-exists=.env --import tsx scripts/check-notion.ts",
    "check:notion-schema": "node --env-file-if-exists=.env --import tsx scripts/ensure-notion-schema.ts --mode=dry-run",
    "check:email": "node --env-file-if-exists=.env --import tsx scripts/check-email.ts",
    "check:routing": "node --env-file-if-exists=.env --import tsx scripts/check-routing.ts",
    "ensure:notion-work-items-schema": "node --env-file-if-exists=.env --import tsx scripts/ensure-notion-work-items-schema.ts",
    "ensure:notion-schema": "node --env-file-if-exists=.env --import tsx scripts/ensure-notion-schema.ts",
    "backfill:people-directory": "node --env-file-if-exists=.env --import tsx scripts/backfill-people-directory.ts",
    "sync-ai": "node scripts/sync-ai-config.mjs",
    "dry-run": "node --env-file-if-exists=.env --import tsx src/app.ts --mode=dry-run",
    "persist-only": "node --env-file-if-exists=.env --import tsx src/app.ts --mode=persist-only",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@notionhq/client": "^5.20.0",
    "@slack/web-api": "^7.12.0",
    "@vercel/node": "^5.4.14",
    "nodemailer": "^8.0.6",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.22",
    "@vitest/coverage-v8": "^4.1.5",
    "nodemon": "^3.1.10",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
